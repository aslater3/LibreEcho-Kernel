#!/bin/busybox sh
# shellcheck shell=dash
# v97-compatible ARM32 recovery control plane.

BB=/bin/busybox
PATH=/bin:/sbin:/system/bin
export PATH
umask 022

$BB mkdir -p /dev/pts /dev/usb-ffs/adb /dev/socket /proc /sys /tmp
$BB chmod 0777 /tmp

# Android init normally mounts these before parsing init.rc.  Keep the script
# usable in a reduced recovery environment without mounting over /dev, because
# doing so would hide Android's property area and break adbd.
$BB grep -q ' /proc ' /proc/mounts 2>/dev/null || $BB mount -t proc proc /proc 2>/dev/null
$BB grep -q ' /sys ' /proc/mounts 2>/dev/null || $BB mount -t sysfs sysfs /sys 2>/dev/null
$BB grep -q ' /dev/pts ' /proc/mounts 2>/dev/null || $BB mount -t devpts devpts /dev/pts 2>/dev/null

log()
{
    printf '%s\n' "$*" >> /tmp/init.log
    printf 'libreecho-init: %s\n' "$*" > /dev/kmsg 2>/dev/null
}

log init-started

# The GPT used by Biscuit exposes expdb as Linux partition 7.  Wait for the
# kernel's block identity, then create direct aliases from sysfs rather than
# assuming MMC minor numbers.
EXPDB=/dev/mmcblk0p7
EXPDB_SYS=/sys/class/block/mmcblk0p7
i=0
while [ "$i" -lt 10 ] && [ ! -r "$EXPDB_SYS/dev" ]; do
    $BB sleep 1
    i=$((i + 1))
done
for sys_block in /sys/class/block/mmcblk0 /sys/class/block/mmcblk0p*; do
    [ -r "$sys_block/dev" ] || continue
    name=${sys_block##*/}
    devno=$($BB cat "$sys_block/dev" 2>/dev/null)
    major=${devno%:*}
    minor=${devno#*:}
    if [ -z "$major" ] || [ -z "$minor" ]; then
        continue
    fi
    [ -b "/dev/$name" ] || $BB mknod "/dev/$name" b "$major" "$minor" 2>/dev/null
done
expdb_devno=$($BB cat "$EXPDB_SYS/dev" 2>/dev/null)
expdb_major=${expdb_devno%:*}
expdb_minor=${expdb_devno#*:}
expected_rdev=
case "$expdb_devno" in
    *:*) expected_rdev=$($BB printf '%x:%x' "$expdb_major" "$expdb_minor") ;;
esac

# This is the first persistent state change.  LK consumes the marker on the
# next reset and enters fastboot, preserving the rapid recovery loop.  Refuse
# the write unless sysfs proves the target is the expected 0x5000-sector expdb
# block partition; this prevents shell redirection from creating a regular file.
if [ -b "$EXPDB" ] && [ -n "$expected_rdev" ] &&
   [ "$($BB stat -c '%t:%T' "$EXPDB" 2>/dev/null)" = "$expected_rdev" ] &&
   $BB grep -qx 'PARTNAME=expdb' "$EXPDB_SYS/uevent" 2>/dev/null &&
   [ "$($BB cat "$EXPDB_SYS/size" 2>/dev/null)" = 20480 ]; then
    if printf FASTBOOT_PLEASE > "$EXPDB" 2>/tmp/expdb-marker.err; then
        $BB sync
        marker=$($BB dd if="$EXPDB" bs=15 count=1 2>/dev/null)
        if [ "$marker" = FASTBOOT_PLEASE ]; then
            log fastboot-please-written
        else
            log fastboot-please-readback-failed
        fi
    else
        log fastboot-please-write-failed
    fi
else
    log expdb-identity-rejected
fi

# Stable MediaTek connectivity aliases.  btif is dynamically allocated and is
# intentionally left to devtmpfs/ueventd.
[ -c /dev/wmtWifi ] || $BB mknod /dev/wmtWifi c 153 0 2>/dev/null
[ -c /dev/wmtdetect ] || $BB mknod /dev/wmtdetect c 154 0 2>/dev/null
[ -c /dev/stpwmt ] || $BB mknod /dev/stpwmt c 190 0 2>/dev/null
[ -e /dev/wmt ] || $BB ln -s stpwmt /dev/wmt 2>/dev/null
[ -c /dev/stpbt ] || $BB mknod /dev/stpbt c 192 0 2>/dev/null
$BB chmod 0666 /dev/wmtWifi /dev/wmtdetect /dev/stpwmt /dev/stpbt 2>/dev/null
log wmt-nodes-created

# Preserve v97's root command loop.  Wi-Fi activation is staged through this
# hook after ADB parity; it must not make PID 1 or recovery depend on WLAN.
runme_loop()
{
    while true; do
        if [ -f /tmp/runme ]; then
            /bin/busybox sh /tmp/runme > /tmp/result 2>&1
            $BB rm -f /tmp/runme
        fi
        $BB sleep 1
    done
}
runme_loop &
log runme-loop-started

USB=/sys/class/android_usb/android0
if [ -d "$USB" ]; then
    log android-usb-found
    $BB sleep 2
    log android-usb-settle-complete

    echo 0 > "$USB/enable" 2>/dev/null
    echo 18D1 > "$USB/idVendor" 2>/dev/null
    echo D001 > "$USB/idProduct" 2>/dev/null
    echo adb > "$USB/f_ffs/aliases" 2>/dev/null
    echo rndis,adb > "$USB/functions" 2>/dev/null
    echo LibreEcho > "$USB/iManufacturer" 2>/dev/null
    echo MT8163-ARM32-recovery > "$USB/iProduct" 2>/dev/null
    serial=$($BB sed -n 's/.*androidboot.serialno=\([^ ]*\).*/\1/p' /proc/cmdline)
    echo "${serial:-G2A0RF0485020316}" > "$USB/iSerial" 2>/dev/null
    log android-ffs-composition-set

    if $BB mount -t functionfs adb /dev/usb-ffs/adb -o uid=2000,gid=2000 2>/tmp/functionfs.log; then
        log functionfs-mounted
        /sbin/adbd --root_seclabel=u:r:su:s0 --device_banner=device > /tmp/adbd.log 2>&1 &
        adbd_pid=$!
        log "adbd-started:$adbd_pid"
        $BB sleep 3
        echo 1 > "$USB/enable" 2>/dev/null
        log android-usb-enabled
    else
        log functionfs-mount-failed
    fi
else
    log android-usb-missing
fi

log init-ready-pid1-managed

# Android init remains PID 1.  Keep this service alive so the runme loop and
# recovery diagnostics survive optional driver failures.
while true; do
    $BB sleep 3600
done
